SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.your-project-ref.supabase.co:5432/postgres
ANTHROPIC_API_KEY=

# Google Calendar OAuth2 (Feature 3)
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI must match exactly: http://localhost:8000/schedule/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/schedule/google/callback

# Microsoft Outlook OAuth2 (Feature 4)
# Register app at: https://portal.azure.com → App registrations → New registration
# Redirect URI: http://localhost:8000/schedule/outlook/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/schedule/outlook/callback
