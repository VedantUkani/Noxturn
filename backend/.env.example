# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.your-project-ref.supabase.co:5432/postgres

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Calendar OAuth2 ────────────────────────────────────────────────────
# Step-by-step setup:
#   1. Go to console.cloud.google.com → Select/create a project
#   2. APIs & Services → Enable APIs → search "Google Calendar API" → Enable
#   3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   4. Application type: Web application
#   5. Authorised redirect URIs: add http://localhost:8000/schedule/google/callback
#   6. Copy Client ID and Client Secret below
#   7. OAuth consent screen → Add test user (your Google account email)
#
# GOOGLE_CLIENT_ID   — looks like: 123456789-abc.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET — looks like: GOCSPX-...
# GOOGLE_REDIRECT_URI  — must exactly match what you registered in step 5
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/schedule/google/callback

# ── Microsoft Outlook / Microsoft 365 OAuth2 ─────────────────────────────────
# Step-by-step setup:
#   1. Go to portal.azure.com → Azure Active Directory → App registrations → New registration
#   2. Name: Noxturn  |  Supported account types: Personal + work/school accounts
#   3. Redirect URI: Web → http://localhost:8000/schedule/outlook/callback
#   4. After creation: Certificates & secrets → New client secret → copy the VALUE (not ID)
#   5. API permissions → Add → Microsoft Graph → Delegated → Calendars.Read → Grant admin consent
#   6. Copy Application (client) ID and client secret value below
#
# MICROSOFT_CLIENT_ID     — looks like: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (GUID)
# MICROSOFT_CLIENT_SECRET — looks like: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MICROSOFT_REDIRECT_URI  — must exactly match what you registered in step 3
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/schedule/outlook/callback

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Keep this secret — anyone with this key can forge tokens.
JWT_SECRET=change-me-generate-a-real-secret

# ── Development flags ─────────────────────────────────────────────────────────
# Set to "1" only when running locally over http (not https).
# Never set this in production.
OAUTHLIB_INSECURE_TRANSPORT=1

# ── All-day calendar event time ───────────────────────────────────────────────
# Hour (0-23) to use as start time for all-day calendar events
ALL_DAY_START_HOUR=8

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
